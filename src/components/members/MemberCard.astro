---
import Github from './Github.astro';

const { member, active = false } = Astro.props;
---

<li
  class="member-card overflow-hidden"
  data-member-active={active ? 'true' : 'false'}
  data-member-login={member.login.toLowerCase()}
  data-member-name={(member.name || '').toLowerCase()}
>
  <img src={member.avatar_url} alt={member.login} class="w-full" />
  <div class="min-w-0 text-left ml-sm">
    <div class="font-bold text-lg">
      {member.name || <span class="text-disabled">(Not Provided)</span>}
    </div>
    <div class="github-link-container">
      <Github />
      <a href={member.html_url} class="github-link truncate">
        {member.login}
      </a>
    </div>
  </div>
</li>

<style>
  .member-card {
    border: 1px solid var(--primary-color);
    border-radius: 10px;
    background-color: white;
  }

  .member-card:hover {
    transform: scale(1.05);
    transition: transform 0.3s ease;
    box-shadow: 0px 3px 10px black;
  }

  .min-w-0 {
    min-width: 0;
  }

  .github-link {
    display: block;
    flex: 1;
    min-width: 0;
  }

  .github-link-container {
    display: flex;
    justify-items: center;
    gap: 8px;
    width: 100%;
    padding-bottom: 8px;
  }
</style>
