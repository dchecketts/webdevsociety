---
import { App } from 'octokit';
import fs from 'node:fs';
import MemberCard from './MemberCard.astro';
import type { OrgEvent, MemberUser } from '../../../types';

const GITHUB_APP_ID = 3702060;
const GITHUB_APP_INSTALLATION_ID = 132060529;
const GITHUB_ORG = 'Web-Design-Development-Society';
const MONTH_MS = 30 * 24 * 60 * 60 * 1000;

function memberLabel(user: MemberUser): string {
  return (user.name || user.login).toLowerCase();
}

function getLastEventAt(
  login: string,
  orgEvents: OrgEvent[],
): string | undefined {
  let latest: string | undefined;
  let latestTime = 0;

  for (const event of orgEvents) {
    if (event.actor.login !== login || !event.created_at) continue;
    const time = new Date(event.created_at).getTime();
    if (!Number.isNaN(time) && time > latestTime) {
      latestTime = time;
      latest = event.created_at;
    }
  }

  return latest;
}

function withLastEventAt(user: MemberUser, orgEvents: OrgEvent[]): MemberUser {
  return {
    ...user,
    last_event_at: getLastEventAt(user.login, orgEvents) ?? null,
  };
}

function isActiveInLastMonth(user: MemberUser): boolean {
  if (!user.last_event_at) return false;
  const lastActivity = new Date(user.last_event_at).getTime();
  return !Number.isNaN(lastActivity) && Date.now() - lastActivity <= MONTH_MS;
}

function sortMembers(users: MemberUser[]): MemberUser[] {
  return [...users].sort((a, b) =>
    memberLabel(a).localeCompare(memberLabel(b)),
  );
}

const app = new App({
  appId: GITHUB_APP_ID,
  privateKey: import.meta.env.GITHUB_APP_TOKEN,
});

const installationOctokit = await app.getInstallationOctokit(
  GITHUB_APP_INSTALLATION_ID,
);

let events: OrgEvent[] = [];
if (!fs.existsSync('./events.json')) {
  const eventsResponse = await installationOctokit.request(
    'GET /orgs/{org}/events',
    {
      org: GITHUB_ORG,
      per_page: 100,
    },
  );

  fs.writeFile(
    './events.json',
    JSON.stringify({ data: eventsResponse.data }),
    'utf8',
    (err) => {
      if (err) {
        console.error(err);
      }
    },
  );

  events = eventsResponse.data;
} else {
  events = JSON.parse(fs.readFileSync('./events.json', 'utf8')).data;
}

let members: MemberUser[] = [];
if (!fs.existsSync('./members.json')) {
  const membersResponse = await installationOctokit.paginate(
    'GET /orgs/{org}/members',
    {
      org: GITHUB_ORG,
      per_page: 20,
    },
  );

  fs.writeFile(
    './members.json',
    JSON.stringify({ data: membersResponse }),
    'utf8',
    (err) => {
      if (err) {
        console.error(err);
      }
    },
  );
}
members = JSON.parse(fs.readFileSync('./members.json', 'utf8')).data;

let users: MemberUser[] = [];
if (!fs.existsSync('./users.json')) {
  for (const member of members) {
    const userResponse = await installationOctokit.request(
      'GET /users/{username}',
      {
        username: member.login,
      },
    );

    users.push({
      ...userResponse.data,
      events: events.reduce((acc, event) => {
        if (
          event.actor.login === member.login &&
          event.type === 'PullRequestEvent' &&
          event.repo.name.startsWith('Web-Design-Development-Society/')
        ) {
          acc++;
        }
        return acc;
      }, 0),
      last_event_at: getLastEventAt(member.login, events) ?? null,
    });
  }

  users = sortMembers(users);

  fs.writeFile(
    './users.json',
    JSON.stringify({ data: users }),
    'utf8',
    (err) => {
      if (err) {
        console.error(err);
      }
    },
  );
} else {
  users = sortMembers(
    JSON.parse(fs.readFileSync('./users.json', 'utf8')).data.map(
      (user: MemberUser) => withLastEventAt(user, events),
    ),
  );
}
---

<div class="mx-sm member-directory">
  <h1 class="text-2xl font-bold mt-sm text-center">Members</h1>
  <div class="filters-container">
    <label class="search-filter" for="member-search">
      <span class="read-only">Search by name or Github Handle</span>
      <input
        id="member-search"
        type="search"
        placeholder="Search by name or handle..."
        autocomplete="off"
      />
    </label>
    <label class="active-only-filter" for="active-only-filter">
      <input type="checkbox" id="active-only-filter" />
      Show active only ({users.filter(isActiveInLastMonth).length})
    </label>
  </div>
  <p id="members-results" class="members-results" aria-live="polite"></p>
  <ul id="member-list">
    {
      users.map((user) => (
        <MemberCard member={user} active={isActiveInLastMonth(user)} />
      ))
    }
  </ul>
  <div class="pagination-controls">
    <button id="members-prev-page" type="button" class="pagination-button">
      Previous
    </button>
    <span id="members-page-indicator" class="pagination-indicator"
      >Page 1 of 1</span
    >
    <button id="members-next-page" type="button" class="pagination-button">
      Next
    </button>
  </div>
</div>

<script>
  const membersPerPage = 20;
  const memberList = document.getElementById('member-list');
  const activeOnlyInput = document.getElementById('active-only-filter');
  const searchInput = document.getElementById('member-search');
  const prevButton = document.getElementById('members-prev-page');
  const nextButton = document.getElementById('members-next-page');
  const pageIndicator = document.getElementById('members-page-indicator');
  const resultsElement = document.getElementById('members-results');

  if (
    memberList &&
    activeOnlyInput instanceof HTMLInputElement &&
    searchInput instanceof HTMLInputElement &&
    prevButton instanceof HTMLButtonElement &&
    nextButton instanceof HTMLButtonElement &&
    pageIndicator &&
    resultsElement
  ) {
    const cards = Array.from(memberList.querySelectorAll('li'));
    let currentPage = 1;

    const updateView = () => {
      const query = searchInput.value.trim().toLowerCase();
      const activeOnly = activeOnlyInput.checked;

      const filteredCards = cards.filter((card) => {
        const isActive = card.dataset.memberActive === 'true';
        const login = card.dataset.memberLogin || '';
        const name = card.dataset.memberName || '';
        const matchesSearch =
          query.length === 0 || login.includes(query) || name.includes(query);
        const matchesActive = !activeOnly || isActive;
        return matchesSearch && matchesActive;
      });

      const totalPages = Math.max(
        1,
        Math.ceil(filteredCards.length / membersPerPage),
      );
      currentPage = Math.min(currentPage, totalPages);
      const start = (currentPage - 1) * membersPerPage;
      const end = start + membersPerPage;
      const paginatedCards = new Set(filteredCards.slice(start, end));

      for (const card of cards) {
        card.style.display = paginatedCards.has(card) ? '' : 'none';
      }

      pageIndicator.textContent = `Page ${currentPage} of ${totalPages}`;
      resultsElement.textContent = `${filteredCards.length} member${
        filteredCards.length === 1 ? '' : 's'
      } found`;

      prevButton.disabled = currentPage <= 1;
      nextButton.disabled = currentPage >= totalPages;
    };

    activeOnlyInput.addEventListener('change', () => {
      currentPage = 1;
      updateView();
    });

    searchInput.addEventListener('input', () => {
      currentPage = 1;
      updateView();
    });

    prevButton.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage -= 1;
        updateView();
      }
    });

    nextButton.addEventListener('click', () => {
      currentPage += 1;
      updateView();
    });

    updateView();
  }
</script>

<style>
  #member-list {
    display: grid;
    gap: 4px;
  }

  .filters-container {
    border: 1px solid var(--primary-color);
    border-radius: 4px;
    padding: 4px;
    margin: 4px 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .active-only-filter {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
  }

  .search-filter {
    width: min(100%, 30rem);
  }

  #member-search {
    border: 1px solid var(--primary-color);
    border-radius: 4px;
    padding: 0.5rem;
    width: 100%;
  }

  .members-results {
    margin: 0.5rem 0;
  }

  .pagination-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .pagination-button {
    border: 1px solid var(--primary-color);
    border-radius: 4px;
    background: white;
    color: var(--primary-color);
    padding: 0.4rem 0.8rem;
    cursor: pointer;
  }

  .pagination-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .read-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  @media screen and (min-width: 480px) {
    #member-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 720px) {
    #member-list {
      grid-template-columns: repeat(4, 1fr);
    }
    .filters-container {
      flex-direction: row;
    }
  }

  @media screen and (min-width: 1024px) {
    #member-list {
      grid-template-columns: repeat(6, 1fr);
    }
  }
</style>
