---
import members from '../../../members.json';
import Officer from './Officer.astro';
---

<h1 class="mx-4">Presidency</h1>
<div id="tablet:presidency">
  <div class="row">
    <Officer
      name="Alex Dombroski"
      title="President"
      avatar="https://avatars.githubusercontent.com/u/145472045?v=4"
    />

    <Officer
      name="Daniel Checketts"
      title="Vice President"
      avatar="https://avatars.githubusercontent.com/u/46506971?v=4"
    />
  </div>
  <div class="row mt-4">
    <Officer
      name="Joshua Walker"
      title="Officer"
      avatar="https://avatars.githubusercontent.com/u/235607494?v=4"
    />

    <Officer
      name="Samuel Pereira"
      title="Officer"
      avatar="https://avatars.githubusercontent.com/u/75548737?v=4"
    />

    <Officer
      name="Kian LaMer"
      title="Officer"
      avatar="https://avatars.githubusercontent.com/u/145629950?v=4"
    />
  </div>
</div>
<div id="presidency-grid">
  <div class="font-bold">Title</div>
  <div class="font-bold">Name</div>
  <div>President</div>
  <div class="name-container">
    <img
      class="small avatar"
      src="https://avatars.githubusercontent.com/u/145472045?v=4"
      alt="Alex Dombroski"
    />
    <span class="name">Alex Dombroski</span>
  </div>
  <div>Vice President</div>
  <div class="name-container">
    <img
      class="avatar small"
      src="https://avatars.githubusercontent.com/u/46506971?v=4"
      alt="Daniel Checketts"
    />
    <span class="name">Daniel Checketts</span>
  </div>
  <div>Officer</div>
  <div>
    <img
      class="avatar small"
      src="https://avatars.githubusercontent.com/u/235607494?v=4"
      alt="Joshua Walker"
    />
    <span class="name">Joshua Walker</span>
  </div>
  <div>Officer</div>
  <div class="name-container">
    <img
      class="avatar small"
      src="https://avatars.githubusercontent.com/u/75548737?v=4"
      alt="Samuel Pereira"
    />
    <span class="name">Samuel Pereira</span>
  </div>
  <div>Officer</div>
  <div class="name-container">
    <img
      class="avatar small"
      src="https://avatars.githubusercontent.com/u/145629950?v=4"
      alt="Kian LaMer"
    />
    <span class="name">Kian LaMer</span>
  </div>
</div>

<style>
  .row {
    display: flex;
    flex-direction: row;
    justify-content: space-around;
  }
  #tablet\:presidency {
    display: none;
  }
  #presidency-grid {
    border: 1px solid var(--primary-color);
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 10px;
    margin-left: 20px;
    padding: 4px;
    width: max-content;
  }
  .small {
    height: 30px;
    width: 30px;
  }
  .name-container {
    display: flex;
    flex-direction: row;
    justify-content: left;
    align-items: center;
    gap: 10px;
  }
  @media screen and (min-width: 720px) {
    #tablet\:presidency {
      display: block;
      background-color: var(--secondary-color);
      border-radius: 15px;
      padding: 1rem;
      width: 80%;
      margin-left: 20px;
    }
    #presidency-grid {
      display: none;
    }
  }
</style>
