---
import '../styles/styles.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

type Props = {
  title?: string;
};

const { title }: Props = Astro.props;

const BASE_URL = import.meta.env.BASE_URL;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      type="image/png"
      href={`${BASE_URL}images/favicons/favicon-96x96.png" sizes="96x96`}
    />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${BASE_URL}images/favicons/favicon.svg`}
    />
    <link rel="shortcut icon" href={`${BASE_URL}images/favicons/favicon.ico`} />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href={`${BASE_URL}images/favicons/apple-touch-icon.png`}
    />
    <meta name="apple-mobile-web-app-title" content="Web Society" />
    <link rel="manifest" href={`${BASE_URL}images/favicons/site.webmanifest`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title ?? 'Web Design & Development Society'}</title>
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
