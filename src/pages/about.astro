---
import SiteLayout from '../layouts/SiteLayout.astro';

const baseUrl = import.meta.env.BASE_URL;
---

<SiteLayout>
  <main>
    <div class="about-us-hero-img-div">
      <img
        class="about-us-hero-img"
        src={`${baseUrl}/images/about/hero.jpg`}
        src="/webdevsociety/"
      />
      <h1 class="about-us-title">About Us</h1>
    </div>
    <div class="mission-statement">
      <h2>Mission Statement</h2>
      <p>
        The BYU-I Web Design and Development Society is dedicated to fostering a
        vibrant and collaborative community for students passionate about
        creating digital experiences. Our mission is to spark interest in web
        development by providing hands-on learning opportunities, promoting
        innovative design, and connecting members with real-world industry
        insights. Through workshops, projects, and mentorship, we empower
        students to develop their skills, explore creative solutions, and
        prepare for successful careers in web development. Together, we aim to
        inspire the next generation of web creators.
      </p>
    </div>
    <div class="three-about-cards">
      <section class="values about-card">
        <h3>Our Values</h3>
        <ul>
          <li>Foster Creativity</li>
          <li>Spark interest in web development</li>
          <li>Connection</li>
          <li>Innovative Design</li>
        </ul>
      </section>
      <section class="quote about-card">
        <h3>"Increase your focus on those things that really matter."</h3>
        <p>-Alvin F. Meredith III</p>
      </section>
      <section class="goals about-card">
        <h3>Our Goals</h3>
        <ul>
          <li>Learn from professionals</li>
          <li>Hands-on practice</li>
          <li>Build resumes</li>
          <li>Find connections</li>
        </ul>
      </section>
    </div>
  </main>
</SiteLayout>

<style>
  #about-us-desc {
    grid-column: 1/2;
    grid-row: 1/2;
    justify-self: center;
    align-self: center;
    font-size: 1.8em;
    color: white;
    font-family: var(--font-family-secondary);
    font-weight: 400;
    font-style: normal;
    text-align: center;
  }

  .about-us-btn {
    color: white;
    text-decoration: none;
    text-align: center;
    align-content: center;
    font-family: var(--font-family-primary);
    font-size: 20px;
    transition: 0.3s ease;
    display: inline-block;
    margin-top: 60px;
    padding: 10px;
    border-radius: 4px;
    background-color: var(--primary-color);
    /* text-shadow: 1px 2px 3px black; */
  }

  .about-us-btn:hover {
    color: var(--primary-color);
    background-color: white;
    border-radius: 5px;
    padding: 10px;
  }

  .about-us-main-text {
    margin: 0;
    text-shadow: 1px 1px 3px black;
  }

  .about-us-hero-img-div {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .about-us-hero-img {
    object-fit: cover;
    height: 600px;
    width: 100%;
    z-index: -6;
  }

  .about-us-title {
    z-index: 6;
    color: var(--primary-color);
    font-family: var(--font-family-secondary);
    font-weight: 500;
    font-size: 90px;
    position: absolute;
    background-color: rgb(255, 255, 255, 0.9);
    padding: 60px 80px;
    border-radius: 10px;
  }

  .mission-statement {
    margin: 7.5% 15%;
    border: solid 5px var(--accent-color);
    padding: 5%;
    border-radius: 10px;
  }

  .mission-statement h2 {
    text-align: center;
    font-size: 40px;
    font-weight: 500;
    margin: 10px 200px;
    padding-bottom: 20px;
    border-bottom: solid var(--primary-color) 3px;
  }

  .mission-statement p {
    padding-top: 20px;
    margin: 10px;
    font-size: 20px;
  }

  .three-about-cards {
    display: flex;
    justify-content: space-around;
    margin: 10% 5%;
  }

  .about-card {
    background-color: var(--primary-color);
    padding: 5%;
    width: 250px;
    color: white;
    border-radius: 10px;
  }

  @media screen and (max-width: 768px) {
    .three-about-cards {
      flex-direction: column;
      margin: 10% 5%;
      flex-direction: column;
      align-items: center;
    }

    .about-card {
      margin: 10px 0px;
    }
  }

  @media screen and (max-width: 1174px) {
    .three-about-cards {
      flex-wrap: wrap;
    }

    .about-card {
      margin: 20px 0px;
    }
  }
</style>
